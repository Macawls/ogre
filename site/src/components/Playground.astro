---
import { templates } from "../data/templates";
const presetsJSON = JSON.stringify(templates);
---

<div class="not-content pg-root">
	<!-- Options card -->
	<div class="pg-options">
		<div class="pg-row">
			<label class="pg-label">Template</label>
			<div class="pg-seg">
				<button class="pg-seg-btn pg-seg-btn--active" data-preset="blog"
					>Blog</button
				>
				<button class="pg-seg-btn" data-preset="event">Event</button>
				<button class="pg-seg-btn" data-preset="product">Product</button>
				<button class="pg-seg-btn" data-preset="repo">Repo</button>
				<button class="pg-seg-btn" data-preset="emoji">Emoji</button>
				<button class="pg-seg-btn" data-preset="rtl">RTL</button>
				<button class="pg-seg-btn" data-preset="tailwind">Tailwind</button>
			</div>
		</div>
		<div class="pg-row">
			<label class="pg-label">Output</label>
			<div class="pg-seg pg-seg--sm">
				<button class="pg-seg-btn pg-seg-btn--active" data-format="svg"
					>SVG</button
				>
				<button class="pg-seg-btn" data-format="png">PNG</button>
				<button class="pg-seg-btn" data-format="jpeg">JPEG</button>
			</div>
			<div class="pg-fields">
				<label class="pg-field">
					<span class="pg-field-label">W</span>
					<input
						id="pg-width"
						type="number"
						value="1200"
						min="1"
						max="4096"
						class="pg-input"
					/>
				</label>
				<span class="pg-times">&times;</span>
				<label class="pg-field">
					<span class="pg-field-label">H</span>
					<input
						id="pg-height"
						type="number"
						value="630"
						min="1"
						max="4096"
						class="pg-input"
					/>
				</label>
				<label
					class="pg-field pg-field--quality"
					id="pg-quality-field"
					style="display:none"
				>
					<span class="pg-field-label">Quality</span>
					<input
						id="pg-quality"
						type="number"
						value="90"
						min="1"
						max="100"
						class="pg-input pg-input--sm"
					/>
				</label>
			</div>
			<button
				id="pg-copy-curl"
				class="pg-curl-btn"
				title="Copy as curl command"
			>
				<svg
					width="14"
					height="14"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					><rect x="9" y="9" width="13" height="13" rx="2"></rect><path
						d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"></path></svg
				>
				<span id="pg-curl-text">curl</span>
			</button>
		</div>
	</div>

	<!-- Split -->
	<div class="pg-split">
		<div class="pg-editor-pane">
			<div id="pg-editor-mount" class="pg-editor-mount"></div>
		</div>
		<div class="pg-preview-pane">
			<div class="pg-preview-inner">
				<div class="pg-img-container">
					<div id="pg-output">
						<div class="pg-placeholder">
							<svg
								width="28"
								height="28"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="1.5"
								><rect x="3" y="3" width="18" height="18" rx="2"></rect><circle
									cx="8.5"
									cy="8.5"
									r="1.5"></circle><path d="M21 15l-5-5L5 21"></path></svg
							>
							<span>Edit HTML to render</span>
						</div>
					</div>
					<div id="pg-loading" class="pg-loading-bar"></div>
				</div>
				<details id="pg-http-details" class="pg-http-details" style="display:none">
					<summary class="pg-http-summary">
						<span>Request &amp; Response</span>
						<span id="pg-http-status" class="pg-http-status-badge"></span>
					</summary>
					<div id="pg-http" class="pg-http"></div>
				</details>
			</div>
		</div>
	</div>
</div>

<script is:inline define:vars={{ presetsJSON }}>
	const API_URL = "https://ogre-api.macawls.dev/render";

	const PRESETS = JSON.parse(presetsJSON);

	let editor = null;
	let currentPreset = "blog";
	let rendering = false;
	let currentObjectURL = null;

	async function loadMonaco() {
		return new Promise((resolve) => {
			const s = document.createElement("script");
			s.src =
				"https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.52.2/min/vs/loader.min.js";
			s.onload = () => {
				require.config({
					paths: {
						vs: "https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.52.2/min/vs",
					},
				});
				window.MonacoEnvironment = {
					getWorkerUrl: () =>
						`data:text/javascript;charset=utf-8,${encodeURIComponent('self.MonacoEnvironment={baseUrl:"https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.52.2/min/"};importScripts("https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.52.2/min/vs/base/worker/workerMain.js");')}`,
				};
				require(["vs/editor/editor.main"], function () {
					const isDark = document.documentElement.dataset.theme !== "light";
					monaco.editor.defineTheme("ogre-dark", {
						base: "vs-dark",
						inherit: true,
						rules: [
							{ token: "tag", foreground: "e06c75" },
							{ token: "attribute.name", foreground: "d19a66" },
							{ token: "attribute.value", foreground: "98c379" },
							{ token: "delimiter", foreground: "abb2bf" },
							{ token: "string", foreground: "98c379" },
						],
						colors: {
							"editor.background": "#282c34",
							"editor.foreground": "#abb2bf",
							"editor.lineHighlightBackground": "#2c313a",
							"editorCursor.foreground": "#528bff",
							"editor.selectionBackground": "#3e4451",
							"editorLineNumber.foreground": "#5c6370",
							"editorLineNumber.activeForeground": "#abb2bf",
							"editorGutter.background": "#282c34",
						},
					});
					monaco.editor.defineTheme("ogre-light", {
						base: "vs",
						inherit: true,
						rules: [
							{ token: "tag", foreground: "e45649" },
							{ token: "attribute.name", foreground: "986801" },
							{ token: "attribute.value", foreground: "50a14f" },
							{ token: "delimiter", foreground: "383a42" },
							{ token: "string", foreground: "50a14f" },
						],
						colors: {
							"editor.background": "#fafafa",
							"editor.foreground": "#383a42",
							"editor.lineHighlightBackground": "#f0f0f1",
							"editorCursor.foreground": "#526fff",
							"editor.selectionBackground": "#dce6fb",
							"editorLineNumber.foreground": "#a0a1a7",
							"editorLineNumber.activeForeground": "#383a42",
							"editorGutter.background": "#fafafa",
						},
					});
					editor = monaco.editor.create(
						document.getElementById("pg-editor-mount"),
						{
							value: PRESETS.blog,
							language: "html",
							theme: isDark ? "ogre-dark" : "ogre-light",
							fontSize: 13,
							fontFamily:
								"'JetBrains Mono', 'Cascadia Code', Consolas, monospace",
							fontLigatures: true,
							lineHeight: 20,
							minimap: { enabled: false },
							scrollBeyondLastLine: false,
							renderLineHighlight: "line",
							padding: { top: 12, bottom: 12 },
							overviewRulerLanes: 0,
							hideCursorInOverviewRuler: true,
							scrollbar: {
								verticalScrollbarSize: 8,
								horizontalScrollbarSize: 8,
							},
							wordWrap: "on",
							tabSize: 2,
							automaticLayout: true,
							bracketPairColorization: { enabled: true },
							guides: { bracketPairs: true },
						},
					);
					resolve();
				});
			};
			document.head.appendChild(s);
		});
	}

	function syncEditorTheme() {
		if (!editor) return;
		const isDark = document.documentElement.dataset.theme !== "light";
		monaco.editor.setTheme(isDark ? "ogre-dark" : "ogre-light");
	}

	const themeObserver = new MutationObserver(syncEditorTheme);
	themeObserver.observe(document.documentElement, {
		attributes: true,
		attributeFilter: ["data-theme"],
	});

	function getFormat() {
		return (
			document.querySelector("[data-format].pg-seg-btn--active")?.dataset
				.format || "svg"
		);
	}

	function formatBytes(bytes) {
		if (bytes < 1024) return bytes + " B";
		if (bytes < 1048576) return (bytes / 1024).toFixed(1) + " KB";
		return (bytes / 1048576).toFixed(1) + " MB";
	}

	function updateQualityVisibility() {
		const fmt = getFormat();
		document.getElementById("pg-quality-field").style.display =
			fmt === "jpeg" ? "" : "none";
	}

	function buildCurl() {
		const format = getFormat();
		const html = editor ? editor.getValue() : "";
		const width = parseInt(document.getElementById("pg-width").value) || 1200;
		const height = parseInt(document.getElementById("pg-height").value) || 630;
		const body = { html, width, height, format };
		if (format === "jpeg")
			body.quality =
				parseInt(document.getElementById("pg-quality").value) || 90;
		const json = JSON.stringify(body);
		const escaped = json.replace(/'/g, "'\\''");
		return `curl -X POST ${API_URL} \\\n  -H 'Content-Type: application/json' \\\n  -d '${escaped}'`;
	}

	function showLoading(show) {
		document
			.getElementById("pg-loading")
			.classList.toggle("pg-loading-bar--visible", show);
	}

	function updateHttpBadge(status, elapsed) {
		const badge = document.getElementById("pg-http-status");
		if (!status) {
			badge.textContent = "";
			return;
		}
		const cls = status >= 200 && status < 300 ? "pg-badge-ok" : "pg-badge-err";
		badge.className = "pg-http-status-badge " + cls;
		badge.textContent = `${status} · ${elapsed}ms`;
	}

	async function doRender() {
		if (!editor || rendering) return;
		rendering = true;
		const output = document.getElementById("pg-output");
		const httpEl = document.getElementById("pg-http");
		const format = getFormat();
		const html = editor.getValue();
		const width = parseInt(document.getElementById("pg-width").value) || 1200;
		const height = parseInt(document.getElementById("pg-height").value) || 630;
		const reqBody = { html, width, height, format };
		if (format === "jpeg") {
			reqBody.quality =
				parseInt(document.getElementById("pg-quality").value) || 90;
		}

		showLoading(true);
		httpEl.innerHTML = "";
		const bodyStr = JSON.stringify(reqBody, null, 2);

		const start = performance.now();
		try {
			const res = await fetch(API_URL, {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify(reqBody),
			});

			const elapsed = (performance.now() - start).toFixed(0);
			showLoading(false);

			const resHeaders = {};
			res.headers.forEach((v, k) => {
				resHeaders[k] = v;
			});

			if (!res.ok) {
				const text = await res.text();
				let msg = text;
				try {
					msg = JSON.parse(text).error || text;
				} catch {}
				output.innerHTML = `<div class="pg-error">${escapeHtml(msg)}</div>`;
				updateHttpBadge(res.status, elapsed);
				httpEl.innerHTML = buildHttpDetail({
					method: "POST",
					path: "/render",
					reqHeaders: { "Content-Type": "application/json" },
					reqBody: bodyStr,
					status: res.status,
					statusText: res.statusText,
					resHeaders,
					resBody: text,
					elapsed,
				});
				rendering = false;
				return;
			}

			if (currentObjectURL) {
				URL.revokeObjectURL(currentObjectURL);
				currentObjectURL = null;
			}

			let responseSize = 0;
			let resBodyPreview = "";
			if (format === "svg") {
				const svgText = await res.text();
				responseSize = new Blob([svgText]).size;
				output.innerHTML = `<div class="pg-img-wrap">${svgText}</div>`;
				resBodyPreview =
					svgText.length > 200 ? svgText.slice(0, 200) + "\u2026" : svgText;
			} else {
				const blob = await res.blob();
				responseSize = blob.size;
				currentObjectURL = URL.createObjectURL(blob);
				output.innerHTML = `<div class="pg-img-wrap"><img src="${currentObjectURL}" alt="Rendered ${format.toUpperCase()}" /></div>`;
				resBodyPreview = `<${format} binary, ${formatBytes(responseSize)}>`;
			}

			updateHttpBadge(res.status, elapsed);
			httpEl.innerHTML = buildHttpDetail({
				method: "POST",
				path: "/render",
				reqHeaders: { "Content-Type": "application/json" },
				reqBody: bodyStr,
				status: res.status,
				statusText: res.statusText,
				resHeaders,
				resBody: resBodyPreview,
				elapsed,
				size: responseSize,
			});
		} catch (err) {
			showLoading(false);
			output.innerHTML = `<div class="pg-error">Connection failed. Is the API running?</div>`;
			const failElapsed = (performance.now() - start).toFixed(0);
			updateHttpBadge(0, failElapsed);
			httpEl.innerHTML = buildHttpDetail({
				method: "POST",
				path: "/render",
				reqHeaders: { "Content-Type": "application/json" },
				reqBody: bodyStr,
				status: 0,
				statusText: "Connection Failed",
				resHeaders: {},
				resBody: "",
				elapsed: failElapsed,
			});
		}
		rendering = false;
	}

	function buildHttpDetail({
		method,
		path,
		reqHeaders,
		reqBody,
		status,
		statusText,
		resHeaders,
		resBody,
		elapsed,
		size,
	}) {
		const statusClass = status >= 200 && status < 300 ? "pg-c-ok" : "pg-c-err";
		const statusLine =
			status === 0
				? `<span class="pg-c-err">ERR</span> ${escapeHtml(statusText)}`
				: `<span class="${statusClass}">${status}</span> ${escapeHtml(statusText)}`;

		const reqHdr = Object.entries(reqHeaders)
			.map(([k, v]) => `${escapeHtml(k)}: ${escapeHtml(v)}`)
			.join("\n");
		const resHdr = Object.entries(resHeaders)
			.map(([k, v]) => `${escapeHtml(k)}: ${escapeHtml(v)}`)
			.join("\n");

		return `
    <div class="pg-http-section">
      <div class="pg-http-title">
        <span class="pg-c-accent">${method}</span> ${escapeHtml(path)}
        <span class="pg-c-dim">&middot; ${elapsed}ms${size ? " &middot; " + formatBytes(size) : ""}</span>
      </div>
    </div>
    <div class="pg-http-section">
      <div class="pg-http-heading">Request Headers</div>
      <pre class="pg-http-pre">${reqHdr}</pre>
    </div>
    <div class="pg-http-section">
      <div class="pg-http-heading">Request Body</div>
      <pre class="pg-http-pre">${escapeHtml(reqBody)}</pre>
    </div>
    <div class="pg-http-section">
      <div class="pg-http-heading">Response &nbsp;${statusLine}</div>
      <pre class="pg-http-pre">${resHdr}</pre>
    </div>
    ${
			resBody
				? `<div class="pg-http-section">
      <div class="pg-http-heading">Response Body</div>
      <pre class="pg-http-pre">${escapeHtml(resBody)}</pre>
    </div>`
				: ""
		}`;
	}

	function escapeHtml(s) {
		const d = document.createElement("div");
		d.textContent = s;
		return d.innerHTML;
	}

	let renderTimeout = null;
	function scheduleRender() {
		clearTimeout(renderTimeout);
		renderTimeout = setTimeout(doRender, 400);
	}

	function selectPreset(key, skipRender) {
		if (!PRESETS[key] || !editor) return;
		currentPreset = key;
		editor.setValue(PRESETS[key]);
		document
			.querySelectorAll("[data-preset]")
			.forEach((p) => p.classList.remove("pg-seg-btn--active"));
		document
			.querySelector(`[data-preset="${key}"]`)
			?.classList.add("pg-seg-btn--active");
		if (!skipRender) {
			updateURL();
			doRender();
		}
	}

	function updateURL() {
		const params = new URLSearchParams();
		const format = getFormat();
		const w = document.getElementById("pg-width").value;
		const h = document.getElementById("pg-height").value;
		const q = document.getElementById("pg-quality").value;
		const html = editor ? editor.getValue() : "";

		if (currentPreset && PRESETS[currentPreset] === html) {
			params.set("template", currentPreset);
		} else if (html) {
			params.set("html", btoa(unescape(encodeURIComponent(html))));
		}
		if (format !== "svg") params.set("format", format);
		if (w !== "1200") params.set("w", w);
		if (h !== "630") params.set("h", h);
		if (format === "jpeg" && q !== "90") params.set("q", q);

		const qs = params.toString();
		const url = window.location.pathname + (qs ? "?" + qs : "");
		history.replaceState(null, "", url);
	}

	function loadFromURL() {
		const params = new URLSearchParams(window.location.search);

		const template = params.get("template");
		if (template && PRESETS[template]) {
			currentPreset = template;
		}

		const format = params.get("format");
		if (format && ["svg", "png", "jpeg"].includes(format)) {
			document
				.querySelectorAll("[data-format]")
				.forEach((b) => b.classList.remove("pg-seg-btn--active"));
			document
				.querySelector(`[data-format="${format}"]`)
				?.classList.add("pg-seg-btn--active");
		}

		const w = params.get("w");
		if (w) document.getElementById("pg-width").value = w;
		const h = params.get("h");
		if (h) document.getElementById("pg-height").value = h;
		const q = params.get("q");
		if (q) document.getElementById("pg-quality").value = q;

		updateQualityVisibility();

		const htmlParam = params.get("html");
		return htmlParam ? decodeURIComponent(escape(atob(htmlParam))) : null;
	}

	document.addEventListener("DOMContentLoaded", async () => {
		const customHtml = loadFromURL();

		await loadMonaco();

		if (customHtml && editor) {
			editor.setValue(customHtml);
			document
				.querySelectorAll("[data-preset]")
				.forEach((p) => p.classList.remove("pg-seg-btn--active"));
			currentPreset = null;
		} else if (currentPreset !== "blog" && editor) {
			selectPreset(currentPreset, true);
		}

		if (editor) {
			editor.onDidChangeModelContent(() => {
				updateURL();
				scheduleRender();
			});
		}
		document.querySelectorAll("[data-preset]").forEach((p) => {
			p.addEventListener("click", () => selectPreset(p.dataset.preset));
		});
		document.querySelectorAll("[data-format]").forEach((f) => {
			f.addEventListener("click", () => {
				document
					.querySelectorAll("[data-format]")
					.forEach((b) => b.classList.remove("pg-seg-btn--active"));
				f.classList.add("pg-seg-btn--active");
				updateQualityVisibility();
				updateURL();
				doRender();
			});
		});
		document.getElementById("pg-width").addEventListener("change", () => {
			updateURL();
			scheduleRender();
		});
		document.getElementById("pg-height").addEventListener("change", () => {
			updateURL();
			scheduleRender();
		});
		document.getElementById("pg-quality").addEventListener("change", () => {
			updateURL();
			scheduleRender();
		});

		document
			.getElementById("pg-copy-curl")
			.addEventListener("click", async () => {
				const text = document.getElementById("pg-curl-text");
				try {
					await navigator.clipboard.writeText(buildCurl());
					text.textContent = "copied";
					setTimeout(() => {
						text.textContent = "curl";
					}, 1500);
				} catch {}
			});

		doRender();
	});
</script>

<style>
	.pg-root {
		max-width: 100%;
		margin-top: -0.5rem;
		font-family: var(--sl-font-system);
	}
	.pg-root *,
	.pg-root *::before,
	.pg-root *::after {
		box-sizing: border-box;
	}

	/* ── Options card ── */
	.pg-options {
		border: 1px solid var(--sl-color-hairline-light);
		border-radius: 10px;
		background: var(--sl-color-gray-6);
		padding: 12px 16px;
		margin-bottom: 10px;
		display: flex;
		flex-direction: column;
		gap: 10px;
	}
	.pg-row {
		display: flex;
		align-items: center;
		gap: 12px;
		flex-wrap: wrap;
	}
	.pg-label {
		font-size: 0.72rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.5px;
		color: var(--sl-color-gray-3);
		width: 64px;
		flex-shrink: 0;
	}

	/* Segmented control */
	.pg-seg {
		display: inline-flex;
		border: 1px solid var(--sl-color-hairline-light);
		border-radius: 8px;
		overflow: hidden;
		background: var(--sl-color-black);
	}
	.pg-seg-btn {
		appearance: none;
		border: none;
		background: transparent;
		font-family: var(--sl-font-system);
		font-size: 0.8rem;
		font-weight: 500;
		padding: 6px 16px;
		color: var(--sl-color-gray-2);
		cursor: pointer;
		transition:
			color 0.12s,
			background 0.12s;
		border-right: 1px solid var(--sl-color-hairline-light);
		line-height: 1.4;
	}
	.pg-seg-btn:last-child {
		border-right: none;
	}
	.pg-seg-btn:hover {
		color: var(--sl-color-white);
		background: var(--sl-color-gray-5);
	}
	.pg-seg-btn--active {
		color: var(--sl-color-white);
		background: var(--sl-color-accent-low);
	}
	.pg-seg--sm .pg-seg-btn {
		font-family: var(--sl-font-system-mono);
		font-size: 0.75rem;
		padding: 6px 14px;
	}

	/* Dimension / quality fields */
	.pg-fields {
		display: flex;
		align-items: center;
		gap: 6px;
		margin-left: 4px;
	}
	.pg-field {
		display: flex;
		align-items: center;
		gap: 4px;
	}
	.pg-field-label {
		font-size: 0.68rem;
		font-weight: 600;
		color: var(--sl-color-gray-3);
		text-transform: uppercase;
		letter-spacing: 0.3px;
	}
	.pg-input {
		width: 60px;
		font-family: var(--sl-font-system-mono);
		font-size: 0.78rem;
		padding: 4px 8px;
		border: 1px solid var(--sl-color-hairline-light);
